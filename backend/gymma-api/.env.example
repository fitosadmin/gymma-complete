# Server
NODE_ENV=development
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://gymma:gymma@localhost:5432/gymma

# Redis
REDIS_URL=redis://localhost:6379

# Auth
ACCESS_TOKEN_SECRET=replace_with_32_byte_hex
REFRESH_TOKEN_SECRET=replace_with_32_byte_hex
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Google OAuth
GOOGLE_CLIENT_ID=

# Storage (Cloudflare R2 / AWS S3)
STORAGE_BUCKET=gymma-media
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@gymma.in
